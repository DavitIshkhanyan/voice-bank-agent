# LiveKit (self-hosted)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_INTERNAL_URL=http://livekit:7880
LIVEKIT_AGENT_NAME=armenian-bank-voice-agent
WEB_CLIENT_ORIGIN=http://localhost:8080

# OpenAI for Armenian STT/LLM/TTS
OPENAI_API_KEY=
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_LLM_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# Retrieval
RETRIEVAL_API_URL=http://localhost:8000
MIN_GROUNDING_SCORE=0.12
CHUNKS_PATH=/app/data/knowledge/processed/chunks.jsonl
RETRIEVER_BACKEND=auto
CHROMA_PERSIST_DIR=/app/data/chroma
CHROMA_COLLECTION=bank_chunks
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

